# Virtual environment
venv/
.venv/
env/

# Environment variables
.env
.env.*
!.env.example

# Raw and processed data (can be large / sensitive)
data/raw/
data/processed/
# test.csv is intentionally tracked despite the exclusion above.
# The deployed Docker image and the /demo API endpoint depend on it being
# present in the repo so that cloud builds (e.g. Render cloning from GitHub)
# have the file available — they don't have access to locally-generated files.
# Same pattern used in .dockerignore.
!data/processed/test.csv

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Build / packaging
dist/
build/
*.egg-info/
*.egg

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Logs
logs/
*.log

# Notebooks
.ipynb_checkpoints/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store
